---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Pendientes | VR Scoreboard">
  <div class="container animate-in">
    <h1>Partidas sin Dueño</h1>
    <p class="subtitle">Asigna los puntajes detectados en los cascos.</p>

    <div class="actions-top">
      <button class="btn btn-secondary btn-sm" id="refresh">Actualizar Lista</button>
    </div>

    <div id="loading" class="state-msg">Cargando partidas pendientes...</div>
    <div id="pend-stack" class="stack">
      <!-- Items -->
    </div>

    <div id="empty" class="empty-state" style="display:none">
      <span class="empty-icon">✨</span>
      <p>Todas las partidas han sido asignadas.</p>
    </div>
    <div id="error" class="state-msg error" style="display:none">
      No se pudo cargar la cola de partidas.
    </div>
    <div id="feedback" class="state-msg success" style="display:none"></div>
    <div id="prefill-msg" class="state-msg info" style="display:none"></div>
    <datalist id="players-datalist"></datalist>

    <div class="pagination">
      <button class="btn btn-ghost" id="prev-page">Anterior</button>
      <span id="page-num">Pagina 1</span>
      <button class="btn btn-ghost" id="next-page">Siguiente</button>
    </div>
  </div>

  <style>
    .actions-top { display: flex; justify-content: flex-end; margin-bottom: 10px; }
    .stack { display: flex; flex-direction: column; gap: 10px; }

    :global(.q-card) {
      background: var(--surface);
      padding: 14px;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      display: flex;
      flex-direction: column;
      gap: 12px;
      box-shadow: var(--ring) 0 0 0 1px;
      transition: transform 0.2s;
    }

    :global(.q-card:active) { transform: scale(0.98); }

    :global(.q-header) { display: flex; justify-content: space-between; align-items: center; }
    :global(.q-time) { font-size: 13px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; }
    :global(.q-score) { font-size: 24px; font-weight: 700; color: var(--text); }

    :global(.q-form) { display: flex; gap: 8px; }
    :global(.q-form input) { flex: 1; }

    .empty-state { text-align: center; padding: 50px 20px; color: var(--text-muted); }
    .empty-icon { font-size: 32px; }
    .state-msg {
      margin: 8px 0 12px;
      padding: 11px 14px;
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      color: var(--text-muted);
      font-weight: 600;
      text-align: center;
      background: rgba(255, 255, 255, 0.08);
    }
    .state-msg.error {
      border-color: rgba(248, 113, 113, 0.45);
      color: #fecaca;
      background: rgba(248, 113, 113, 0.1);
    }
    .state-msg.success {
      border-color: rgba(34, 197, 94, 0.4);
      color: #bbf7d0;
      background: rgba(34, 197, 94, 0.12);
    }
    .state-msg.info {
      border-color: rgba(0, 153, 255, 0.45);
      color: #bae6fd;
      background: rgba(0, 153, 255, 0.12);
    }

    .pagination {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 14px;
      padding-top: 10px;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
    }
  </style>

  <script>
    const API = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8000";
    const fmt = (v: any) => new Intl.NumberFormat("es-EC").format(v || 0);
    const PAGE_SIZE = 10;
    const stack = document.getElementById("pend-stack")!;
    const loading = document.getElementById("loading")!;
    const empty = document.getElementById("empty")!;
    const error = document.getElementById("error")!;
    const feedback = document.getElementById("feedback")!;
    const prevPageBtn = document.getElementById("prev-page") as HTMLButtonElement;
    const nextPageBtn = document.getElementById("next-page") as HTMLButtonElement;
    const pageNum = document.getElementById("page-num")!;
    const prefillMsg = document.getElementById("prefill-msg")!;
    const playersDatalist = document.getElementById("players-datalist") as HTMLDataListElement;
    const prefillCedula = new URLSearchParams(window.location.search).get("cedula")?.trim() || "";
    let page = 0;
    let allItems: any[] = [];
    let jugadoresCache: any[] = [];

    function showFeedback(msg: string) {
      feedback.textContent = msg;
      feedback.style.display = "block";
      setTimeout(() => {
        feedback.style.display = "none";
      }, 1800);
    }

    async function load() {
      loading.style.display = "block";
      error.style.display = "none";
      empty.style.display = "none";
      try {
        await loadJugadoresAutocomplete();
        const r = await fetch(`${API}/api/puntajes/pendientes`);
        if (!r.ok) throw new Error("api_error");
        const d = await r.json();
        allItems = d.data || [];
        loading.style.display = "none";

        const maxPage = Math.max(0, Math.ceil(allItems.length / PAGE_SIZE) - 1);
        if (page > maxPage) page = maxPage;
        renderPage();
      } catch {
        loading.style.display = "none";
        stack.innerHTML = "";
        error.style.display = "block";
        pageNum.textContent = "Pagina 1";
        prevPageBtn.disabled = true;
        nextPageBtn.disabled = true;
      }
    }

    function renderPage() {
      const start = page * PAGE_SIZE;
      const pageItems = allItems.slice(start, start + PAGE_SIZE);
      const maxPage = Math.max(0, Math.ceil(allItems.length / PAGE_SIZE) - 1);

      empty.style.display = allItems.length ? "none" : "block";
      pageNum.textContent = `Pagina ${page + 1}`;
      prevPageBtn.disabled = page === 0;
      nextPageBtn.disabled = page >= maxPage || allItems.length === 0;

      stack.innerHTML = pageItems.map((item: any) => {
        const t = new Date(`${item.fecha_juego}-05:00`).toLocaleTimeString("es-EC", { hour: "2-digit", minute: "2-digit" });
        return `
          <div class="q-card animate-in">
            <div class="q-header">
              <span class="q-time">${t} • Estación 1</span>
              <span class="q-score">${fmt(item.puntaje)}</span>
            </div>
            <div class="q-form">
              <input type="text" id="in-${item.id}" class="assign-input" list="players-datalist" placeholder="Cédula o nombre del jugador..." />
              <button class="btn btn-primary btn-sm assign-btn" data-id="${item.id}">Asignar</button>
            </div>
          </div>
        `;
      }).join("");

      if (prefillCedula) {
        const firstInput = stack.querySelector(".assign-input") as HTMLInputElement | null;
        if (firstInput) {
          firstInput.value = prefillCedula;
          firstInput.focus();
          prefillMsg.textContent = `Cédula pre-cargada: ${prefillCedula}. Solo selecciona la partida y asigna.`;
          prefillMsg.style.display = "block";
        }
      }
    }

    async function loadJugadoresAutocomplete() {
      if (jugadoresCache.length) return;
      const r = await fetch(`${API}/api/jugadores`);
      if (!r.ok) throw new Error("players_error");
      const d = await r.json();
      jugadoresCache = d.data || [];
      playersDatalist.innerHTML = jugadoresCache.map((j: any) =>
        `<option value="${j.cedula}" label="${j.nombre}"></option>`
      ).join("");
    }

    function resolveCedula(inputValue: string) {
      const raw = inputValue.trim();
      if (!raw) return "";
      const exactCedula = jugadoresCache.find((j: any) => j.cedula === raw);
      if (exactCedula) return exactCedula.cedula;
      const byName = jugadoresCache.find((j: any) => j.nombre?.toLowerCase() === raw.toLowerCase());
      if (byName) return byName.cedula;
      const cedPrefix = raw.match(/^\d+/)?.[0];
      return cedPrefix || raw;
    }

    async function asignar(pid: string) {
      const raw = (document.getElementById(`in-${pid}`) as HTMLInputElement).value;
      const ced = resolveCedula(raw);
      if (!ced) return;

      try {
        const r1 = await fetch(`${API}/api/jugadores?q=${encodeURIComponent(ced)}`);
        if (!r1.ok) throw new Error("lookup_error");
        const d1 = await r1.json();
        const j = (d1.data || []).find((x: any) => x.cedula === ced);
        
        if (!j) {
          showFeedback("Jugador no registrado.");
          return;
        }

        const r2 = await fetch(`${API}/api/puntajes/${pid}/asignar`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ jugador_id: j.id })
        });
        if (!r2.ok) throw new Error("assign_error");
        showFeedback("Partida asignada.");
        load();
      } catch {
        showFeedback("No se pudo asignar la partida.");
      }
    }

    stack.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest(".assign-btn") as HTMLButtonElement | null;
      if (!btn) return;
      const pid = btn.dataset.id;
      if (pid) asignar(pid);
    });

    prevPageBtn.addEventListener("click", () => {
      if (page === 0) return;
      page--;
      renderPage();
    });

    nextPageBtn.addEventListener("click", () => {
      const maxPage = Math.max(0, Math.ceil(allItems.length / PAGE_SIZE) - 1);
      if (page >= maxPage) return;
      page++;
      renderPage();
    });

    document.getElementById("refresh")?.addEventListener("click", load);
    window.addEventListener("DOMContentLoaded", load);
  </script>
</MainLayout>
