---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Registro | VR Scoreboard">
  <div class="container registro-shell animate-in">
    <h1>Nuevo Registro</h1>
    <p class="subtitle">Valida la identidad del participante.</p>

    <div class="card main-form">
      <!-- Etapa 1: Cédula -->
      <div class="field">
        <label for="cedula">Documento de Identidad</label>
        <div class="input-inline">
          <input type="text" id="cedula" placeholder="060XXXXXXX" inputmode="numeric" maxlength="15" />
          <button class="btn btn-primary" id="btn-validar">Validar</button>
        </div>
      </div>

      <!-- Etapa 2: Feedback ERP -->
      <div id="status-card" class="status-card" style="display:none">
        <div class="status-icon"></div>
        <div class="status-info">
          <div id="status-title" class="status-title">Validando...</div>
          <div id="status-msg" class="status-msg">Consultando base de datos Fibra.</div>
        </div>
      </div>

      <!-- Etapa 3: Datos Secundarios -->
      <div class="secondary-fields">
        <div class="field">
          <label for="nombre">Nombre Completo</label>
          <input type="text" id="nombre" placeholder="Nombre Apellido" />
        </div>
        <div class="field">
          <label for="telefono">Teléfono de Contacto</label>
          <input type="tel" id="telefono" placeholder="099XXXXXXX" />
        </div>
      </div>

      <input type="hidden" id="is-cliente" value="false" />
      
      <button class="btn btn-primary btn-full" id="btn-guardar">Registrar Participante</button>
      <button class="btn btn-secondary btn-full quick-assign-btn" id="btn-go-pendientes" style="display:none">
        Ir a Asignar Partidas Pendientes
      </button>
      <div id="feedback" class="feedback-toast" style="display:none"></div>
      <div id="error-card" class="status-card warn" style="display:none">
        <div class="status-info">
          <div class="status-title">No se pudo completar la acción</div>
          <div id="error-msg" class="status-msg">Revisa la conexión e intenta otra vez.</div>
        </div>
      </div>
    </div>
  </div>

  <style>
    :global(body) { overflow: hidden; }
    .registro-shell {
      min-height: calc(100dvh - 94px);
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-top: 12px;
      padding-bottom: 12px;
    }

    .main-form { margin-bottom: 0; }
    .input-inline { display: flex; gap: 12px; }
    .input-inline input { flex: 1; }

    .status-card {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 12px;
      border-radius: 10px;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.16);
      margin-bottom: 14px;
      animation: fadeIn 0.3s ease;
    }

    .status-card.ok { background: rgba(37, 195, 107, 0.12); border-color: rgba(37, 195, 107, 0.5); }
    .status-card.warn { background: rgba(255, 77, 77, 0.12); border-color: rgba(255, 77, 77, 0.45); }

    .status-title { font-weight: 700; font-size: 15px; color: var(--text); }
    .status-msg { font-size: 13px; color: var(--text-muted); }

    .secondary-fields { margin-top: 4px; }
    .quick-assign-btn { margin-top: 10px; }

    .feedback-toast {
      position: fixed;
      top: 24px;
      left: 50%;
      transform: translateX(-50%);
      background: #ffffff;
      color: #000000;
      padding: 12px 24px;
      border-radius: 999px;
      font-weight: 600;
      box-shadow: var(--ring) 0 0 0 2px;
      z-index: 2000;
    }

    @media (min-width: 768px) {
      :global(body) { overflow: auto; }
      .registro-shell {
        min-height: calc(100dvh - 110px);
        max-width: 680px;
      }
    }

    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  </style>

  <script>
    const API = import.meta.env.PUBLIC_API_BASE_URL || "http://127.0.0.1:8000";

    const cedInp = document.getElementById("cedula") as HTMLInputElement;
    const nomInp = document.getElementById("nombre") as HTMLInputElement;
    const telInp = document.getElementById("telefono") as HTMLInputElement;
    const isCli = document.getElementById("is-cliente") as HTMLInputElement;
    
    const statusCard = document.getElementById("status-card")!;
    const statusTitle = document.getElementById("status-title")!;
    const statusMsg = document.getElementById("status-msg")!;
    const errorCard = document.getElementById("error-card")!;
    const errorMsg = document.getElementById("error-msg")!;
    const btnValidar = document.getElementById("btn-validar") as HTMLButtonElement;
    const btnGuardar = document.getElementById("btn-guardar") as HTMLButtonElement;
    const btnGoPendientes = document.getElementById("btn-go-pendientes") as HTMLButtonElement;
    let cedulaYaRegistrada = false;

    function setBusy(btn: HTMLButtonElement, busy: boolean, text: string, idleText: string) {
      btn.disabled = busy;
      btn.textContent = busy ? text : idleText;
    }

    function showError(msg: string) {
      errorMsg.textContent = msg;
      errorCard.style.display = "flex";
    }

    function setGuardarHabilitado(habilitado: boolean) {
      btnGuardar.disabled = !habilitado;
      btnGuardar.textContent = habilitado ? "Registrar Participante" : "Participante Ya Registrado";
    }

    function limpiarDatosDerivados() {
      nomInp.value = "";
      telInp.value = "";
      isCli.value = "false";
      statusCard.style.display = "none";
      btnGoPendientes.style.display = "none";
      statusCard.className = "status-card";
      statusTitle.textContent = "Validando...";
      statusMsg.textContent = "Consultando base de datos Fibra.";
    }

    function mostrarAtajoPendientes(cedula: string) {
      if (!cedula) return;
      btnGoPendientes.style.display = "inline-flex";
      btnGoPendientes.textContent = "Asignar Score Ahora";
      btnGoPendientes.onclick = () => {
        window.location.href = `/pendientes?cedula=${encodeURIComponent(cedula)}`;
      };
      statusCard.style.display = "flex";
      statusCard.className = "status-card ok";
      statusTitle.textContent = "Accion Recomendada";
      statusMsg.textContent = "Puedes asignar partidas pendientes de este jugador ahora mismo.";
      btnGoPendientes.scrollIntoView({ behavior: "smooth", block: "center" });
    }

    async function validar() {
      if (cedInp.value.length < 5) return;
      errorCard.style.display = "none";
      setBusy(btnValidar, true, "Validando...", "Validar");
      cedulaYaRegistrada = false;
      setGuardarHabilitado(true);
      
      statusCard.style.display = "flex";
      statusCard.className = "status-card";
      statusTitle.textContent = "Consultando...";
      statusMsg.textContent = "Buscando en base de datos externa.";

      try {
        const localResp = await fetch(`${API}/api/jugadores?q=${encodeURIComponent(cedInp.value.trim())}`);
        if (!localResp.ok) throw new Error("local_lookup_error");
        const localData = await localResp.json();
        const jugadorExistente = (localData.data || []).find((j: any) => j.cedula === cedInp.value.trim());

        if (jugadorExistente) {
          cedulaYaRegistrada = true;
          statusCard.classList.add("warn");
          statusTitle.textContent = "Participante Ya Registrado";
          statusMsg.textContent = "Esta cédula ya existe en el sistema.";
          nomInp.value = jugadorExistente.nombre || "";
          telInp.value = jugadorExistente.telefono || "";
          isCli.value = jugadorExistente.is_cliente ? "true" : "false";
          setGuardarHabilitado(false);
          mostrarAtajoPendientes(cedInp.value.trim());
          return;
        }

        const r = await fetch(`${API}/api/jugadores/lookup/${encodeURIComponent(cedInp.value)}`);
        const d = await r.json();
        const data = d.data || {};

        if (data.available && data.is_cliente) {
          statusCard.classList.add("ok");
          statusTitle.textContent = "Cliente Verificado";
          statusMsg.textContent = "Se han recuperado los datos automáticamente.";
          nomInp.value = data.nombre || "";
          telInp.value = data.telefono || "";
          isCli.value = "true";
        } else {
          statusCard.classList.add("warn");
          statusTitle.textContent = "Visitante Nuevo";
          statusMsg.textContent = "Por favor ingresa los datos manualmente.";
          isCli.value = "false";
        }
      } catch {
        statusCard.classList.add("warn");
        statusTitle.textContent = "No se pudo validar";
        statusMsg.textContent = "Puedes continuar con registro manual.";
        showError("Error consultando la base externa.");
      } finally {
        setBusy(btnValidar, false, "Validando...", "Validar");
      }
    }

    async function guardar() {
      errorCard.style.display = "none";
      const payload = {
        nombre: nomInp.value.trim(),
        cedula: cedInp.value.trim(),
        telefono: telInp.value.trim(),
        is_cliente: isCli.value === "true"
      };

      if (!payload.nombre || !payload.cedula) {
        showError("Nombre y documento son obligatorios.");
        return;
      }
      if (!payload.telefono || payload.telefono.length < 6) {
        showError("El teléfono debe tener al menos 6 caracteres.");
        return;
      }

      if (cedulaYaRegistrada) {
        showError("Este participante ya se encuentra registrado.");
        return;
      }

      setBusy(btnGuardar, true, "Registrando...", "Registrar Participante");

      try {
        const r = await fetch(`${API}/api/jugadores`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });
        if (r.ok) {
          showToast("¡Jugador Registrado!");
          mostrarAtajoPendientes(payload.cedula);
          cedulaYaRegistrada = true;
          setGuardarHabilitado(false);
          setTimeout(() => {
            const t = document.getElementById("feedback")!;
            t.style.display = "none";
          }, 1600);
        } else {
          let serverMsg = "No se pudo registrar el participante.";
          try {
            const err = await r.json();
            if (err?.message) serverMsg = err.message;
            if (err?.data?.errors?.length) {
              const firstError = err.data.errors[0];
              const field = Array.isArray(firstError?.loc) ? firstError.loc.at(-1) : "";
              const msg = firstError?.msg || "";
              if (field || msg) {
                serverMsg = `Validación ${field ? `"${field}"` : "de datos"}: ${msg}`;
              }
            }
          } catch {}
          showError(serverMsg);
        }
      } catch {
        showError("Error de red al registrar participante.");
      } finally {
        setBusy(btnGuardar, false, "Registrando...", "Registrar Participante");
      }
    }

    function showToast(msg: string) {
      const t = document.getElementById("feedback")!;
      t.textContent = msg;
      t.style.display = "block";
    }

    document.getElementById("btn-validar")?.addEventListener("click", validar);
    document.getElementById("btn-guardar")?.addEventListener("click", guardar);
    cedInp.addEventListener("input", () => {
      cedulaYaRegistrada = false;
      setGuardarHabilitado(true);
      errorCard.style.display = "none";
      limpiarDatosDerivados();
    });
  </script>
</MainLayout>
