---
const path = Astro.url.pathname;
import brandLogo from "../../logo_fibra.jpg";
const links = [
  { href: "/", label: "Ranking", icon: `<path d="M12 20V10M18 20V4M6 20v-4" />` },
  { href: "/registro", label: "Registro", icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="16" y1="11" x2="22" y2="11" />` },
  { href: "/pendientes", label: "Partidas", icon: `<rect x="2" y="3" width="20" height="14" rx="2" ry="2" /><line x1="8" y1="21" x2="16" y2="21" /><line x1="12" y1="17" x2="12" y2="21" />` }
];
const isActiveLink = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));
---

<nav class="bottom-nav" aria-label="Navegacion principal">
  <div class="nav-links">
    {
      links.map((link) => (
        <a
          href={link.href}
          class={`nav-item ${isActiveLink(link.href) ? "active" : ""}`}
        >
          <svg viewBox="0 0 24 24" set:html={link.icon} />
          <span>{link.label}</span>
        </a>
      ))
    }
  </div>
  <a href="/" class="nav-brand" aria-label="Inicio">
    <img src={brandLogo.src} alt="Fibra Telecom" />
  </a>
</nav>
